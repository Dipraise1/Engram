        "summary": "GET /commitment \u2014 returns the Merkle root of this miner's full memory corpus.",
        "responses": {
          "200": {
            "description": "Successful operation"
          }
        }
      }
    },
    "/prove-memory": {
      "post": {
        "summary": "POST /prove-memory \u2014 return a Merkle inclusion proof for one CID.",
        "responses": {
          "200": {
            "description": "Successful operation"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        }
      }
    }
  }
}