{
  "components": {
    "securitySchemes": {
      "NamespaceSignature": {
        "description": "Logical scheme: namespace ownership proof fields are sent in JSON request bodies.",
        "in": "query",
        "name": "namespace_hotkey/namespace_sig/namespace_timestamp_ms",
        "type": "apiKey"
      },
      "SignedBody": {
        "description": "Logical scheme: sr25519 signature fields are sent in JSON request bodies.",
        "in": "query",
        "name": "hotkey/nonce/signature",
        "type": "apiKey"
      }
    }
  },
  "info": {
    "description": "Machine-readable API contract for neurons/miner.py. Signed miner requests use hotkey, nonce, and signature fields in the JSON body. Namespace-scoped requests use namespace_hotkey, namespace_sig, and namespace_timestamp_ms.",
